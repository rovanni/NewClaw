/**
 * ResponseAdapter — LLM Response Layer (Adapter Universal)
 *
 * CONTRACT: This is the ONLY layer that reads raw LLM response formats
 * for the STRUCTURED flow (AgentLoop + tools).
 *
 * For SIMPLE flows (compressor, validator, onboarding), use
 * ContentExtractor.extractText() — lightweight, returns string only.
 *
 * Priority chain:
 *   1. Atomic JSON (action.content)  — NewClaw structured format
 *   2. OpenAI-like (choices[0].message.content)
 *   3. Direct content (.content)     — Ollama / generic
 *   4. Sanitized fallback
 *   5. Empty string — caller decides what to do
 *
 * Extensibility: add new parser functions for new providers without
 * touching any consumer code.
 */

import { sanitizeContent } from './ContentExtractor';

// ── Public Types ──────────────────────────────────────────────────────────────

/**
 * The canonical response type for the STRUCTURED flow.
 *
 * `text`      — The human-readable response text (always extracted from the
 *               highest-priority source available).
 * `toolCalls` — Native tool calls, if any.
 * `raw`       — The original, unmodified LLM response for logging/debugging.
 */
export interface NormalizedResponse {
    text: string;
    toolCalls?: any[];
    raw: any;
}

// ── Provider-specific parsers ────────────────────────────────────────────────

/**
 * Parse atomic JSON format: { thought, action: { type, content, name, input, toolCalls }, evaluation }
 * Used by NewClaw's own prompt pattern.
 */
function parseAtomicFormat(raw: any): { text: string | null; toolCalls: any[] | null } {
    let parsed: any = raw;
    if (typeof raw === 'string') {
        try { parsed = JSON.parse(raw); } catch { return { text: null, toolCalls: null }; }
    }
    if (!parsed || typeof parsed !== 'object') return { text: null, toolCalls: null };

    if (parsed.action?.content && typeof parsed.action.content === 'string' && parsed.action.content.trim().length > 0) {
        return {
            text: parsed.action.content,
            toolCalls: parsed.action.type === 'tool_call' ? (parsed.action.toolCalls || null) : null
        };
    }
    return { text: null, toolCalls: null };
}

/**
 * Parse OpenAI-compatible format: { choices: [{ message: { content, tool_calls } }] }
 */
function parseOpenAIFormat(raw: any): { text: string | null; toolCalls: any[] | null } {
    const message = raw?.choices?.[0]?.message;
    if (!message) return { text: null, toolCalls: null };
    return {
        text: message.content || null,
        toolCalls: message.tool_calls || null
    };
}

/**
 * Parse Ollama / generic format: { content: string, toolCalls?: any[] }
 * This is the LLMResult format from ProviderFactory.
 */
function parseGenericFormat(raw: any): { text: string | null; toolCalls: any[] | null } {
    if (raw?.content && typeof raw.content === 'string' && raw.content.trim().length > 0) {
        return { text: raw.content, toolCalls: raw.toolCalls || null };
    }
    return { text: null, toolCalls: null };
}

// ── Main Adapter ─────────────────────────────────────────────────────────────

/**
 * Transform ANY LLM response into a NormalizedResponse.
 *
 * Used by: AgentLoop (structured flow with toolCalls + raw).
 * NOT for: simple flows — use ContentExtractor.extractText() instead.
 *
 * Priority:
 *   1. Atomic JSON (action.content)
 *   2. OpenAI-like (choices[0].message.content)
 *   3. Generic (raw.content) — Ollama / ProviderFactory
 *   4. Sanitized fallback
 *   5. Empty string — caller must handle
 */
export function normalizeResponse(raw: any): NormalizedResponse {
    // Priority 1: Atomic format { action: { content } }
    const atomic = parseAtomicFormat(raw);
    if (atomic.text) {
        return { text: atomic.text, toolCalls: atomic.toolCalls || raw?.toolCalls || undefined, raw };
    }

    // Priority 2: OpenAI-like format
    const openai = parseOpenAIFormat(raw);
    if (openai.text) {
        return { text: openai.text, toolCalls: openai.toolCalls || undefined, raw };
    }

    // Priority 3: Generic { content, toolCalls }
    const generic = parseGenericFormat(raw);
    if (generic.text) {
        return { text: generic.text, toolCalls: generic.toolCalls || undefined, raw };
    }

    // Priority 4: Sanitize whatever we got
    const rawStr = typeof raw === 'string' ? raw : (raw?.content || '');
    const sanitized = sanitizeContent(rawStr);
    if (sanitized.length > 0) {
        return { text: sanitized, toolCalls: raw?.toolCalls || undefined, raw };
    }

    // Priority 5: Truly empty — caller must handle
    return { text: '', toolCalls: raw?.toolCalls || undefined, raw };
}