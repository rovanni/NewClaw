{
  "name": "newclaw",
  "version": "1.0.0",
  "description": "Agente pessoal de IA 100% local com Telegram",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs'); fs.mkdirSync('dist/dashboard', {recursive:true}); fs.cpSync('src/dashboard/public', 'dist/dashboard/public', {recursive:true, force:true})\"",
    "start": "node dist/index.js",
    "start:debug": "node --inspect dist/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "grammy": "^1.21.0",
    "p-queue": "^9.1.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/form-data": "^2.2.1",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
