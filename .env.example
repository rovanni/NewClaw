# Thorial - Variáveis de ambiente

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Idioma (pt-BR, en-US, es-ES)
APP_LANG=pt-BR

# Provider padrão (gemini, deepseek, groq, ollama)
DEFAULT_PROVIDER=gemini

# API Keys
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# Ollama (local)
OLLAMA_URL=http://localhost:11434

# Config
MAX_ITERATIONS=5
MEMORY_WINDOW_SIZE=20
SKILLS_DIR=./skills
TMP_DIR=./tmp
WHISPER_PATH=/usr/local/bin/whisper

# Dashboard Web
DASHBOARD_PORT=3090