# NewClaw — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# ─── Identidade do Dono (ESSENCIAL para agente single-owner) ──
# Nome do proprietário permanente deste sistema.
# Após configurado, o LLM não consegue alterar esta identidade.
OWNER_NAME=
# ID do usuário principal (ex: ID do Telegram do dono)
OWNER_USER_ID=
# Se true, bloqueia qualquer alteração automática da identidade do dono.
# Recomendado: true após concluir o onboarding.
OWNER_LOCKED=false

# ─── Telegram (canal principal) ───────────────────────────────
# Token do bot: Telegram → @BotFather → /newbot → copie o token
TELEGRAM_BOT_TOKEN=
# Seu ID de usuário: Telegram → @userinfobot → copie o ID
TELEGRAM_ALLOWED_USER_IDS=

# ─── Discord (opcional) ──────────────────────────────────────
# Token do bot: Discord → Developer Portal → Bot → Token
DISCORD_BOT_TOKEN=
# IDs dos servidores permitidos (vazio = todos)
DISCORD_ALLOWED_GUILD_IDS=
# IDs de usuários permitidos (vazio = todos nos guilds permitidos)
DISCORD_ALLOWED_USER_IDS=

# ─── WhatsApp (opcional) ─────────────────────────────────────
# Número de telefone com código do país (ex: +5511999999999)
WHATSAPP_PHONE_NUMBER=
# JIDs permitidos (vazio = todos os contatos)
WHATSAPP_ALLOWED_JIDS=
# Diretório de autenticação (sessão WhatsApp)
WHATSAPP_AUTH_DIR=./data/whatsapp-auth

# ─── Signal (opcional) ───────────────────────────────────────
# Número de telefone com código do país (ex: +5511999999999)
SIGNAL_PHONE_NUMBER=
# Números permitidos (vazio = todos)
SIGNAL_ALLOWED_NUMBERS=
# Caminho do signal-cli (padrão: signal-cli)
SIGNAL_CLI_PATH=signal-cli

# ─── Idioma ───────────────────────────────────────────────────
# Opções: pt-BR | en-US | es-ES
APP_LANG=pt-BR

# ─── Provider padrão ─────────────────────────────────────────
# Opções: ollama | openrouter | gemini | deepseek | groq
DEFAULT_PROVIDER=ollama

# ─── API Keys (opcional — apenas se usar providers em nuvem) ──
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ─── Ollama (local / nuvem) ───────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=glm-5.2:cloud
# Deixe vazio se não usa autenticação no Ollama
OLLAMA_API_KEY=

# ─── Modelos dos templates de conversa ───────────────────────
# Nome do modelo compatível com DEFAULT_PROVIDER (ou com PROVIDER_* do perfil).
# Ollama:      MODEL_CHAT=glm-5.2:cloud
# OpenRouter:  MODEL_CHAT=anthropic/claude-3.5-sonnet
# Gemini:      MODEL_CHAT=gemini-2.0-flash
# ChatGPT:     MODEL_CHAT=gpt-4o
MODEL_CHAT=
MODEL_CODE=
MODEL_VISION=
MODEL_LIGHT=
MODEL_ANALYSIS=
MODEL_EXECUTION=

# ─── Provider por perfil (opcional) ──────────────────────────
# Permite usar providers diferentes por categoria de conversa.
# Se não definido, usa DEFAULT_PROVIDER para todos os perfis.
# Exemplo: usar Gemini para chat e OpenRouter para código:
#   PROVIDER_CHAT=gemini
#   PROVIDER_CODE=openrouter
PROVIDER_CHAT=
PROVIDER_CODE=
PROVIDER_VISION=
PROVIDER_LIGHT=
PROVIDER_ANALYSIS=
PROVIDER_EXECUTION=

# ─── Modelos dos componentes internos ────────────────────────
# Nome compatível com DEFAULT_PROVIDER.
# Ollama:      PLANNER_MODEL=gemma4:31b-cloud
# OpenRouter:  PLANNER_MODEL=google/gemini-2.0-flash
# Gemini:      PLANNER_MODEL=gemini-2.0-flash
# ChatGPT:     PLANNER_MODEL=gpt-4o-mini
PLANNER_MODEL=
RISK_MODEL=
OBSERVER_MODEL=

# ─── Modelos customizados (gerenciado pelo dashboard) ─────────
# Lista separada por vírgulas. Não editar manualmente.
CUSTOM_MODELS=

# ─── Diagnóstico de contaminação de memória (opcional) ────────
# Termos pessoais/sensíveis (separados por vírgula) que o ContextBuilder e o SessionContext
# checam nos logs [USER-EXPANDED]/[FINAL-CONTEXT] pra auditar se vazaram pra um contexto não
# relacionado. Feature só de diagnóstico — não bloqueia nem filtra nada sozinha. Deixe vazio
# se não quiser essa auditoria; cada instalação define os seus próprios termos aqui (arquivo
# local, nunca versionado) em vez de hardcoded no código-fonte.
# Exemplo: CONTAMINATION_WATCH_TERMS=minha-cidade,meu-time,minha-empresa
CONTAMINATION_WATCH_TERMS=

# ─── Logging ─────────────────────────────────────────────────
# Caminho do arquivo de log de auditoria (sem ANSI). Padrão: definido no ecosystem.config.cjs
# Defina aqui para sobrescrever ao rodar fora do PM2 (ex: npm start direto).
LOG_FILE=./logs/newclaw-audit.log
# Nível de log: debug | info | warn | error (padrão: info)
LOG_LEVEL=info

# ─── Config ───────────────────────────────────────────────────
MAX_ITERATIONS=8
MEMORY_WINDOW_SIZE=20
SKILLS_DIR=./skills
WORKSPACE_DIR=./workspace
TMP_DIR=./workspace/tmp

# ─── Dashboard Web ────────────────────────────────────────────
DASHBOARD_PORT=3090
# Interface de rede (default 127.0.0.1 = somente localhost).
# Para expor em LAN/proxy reverso use 0.0.0.0 — e OBRIGATORIAMENTE defina DASHBOARD_PASSWORD.
DASHBOARD_HOST=127.0.0.1
# Senha do dashboard. Sem ela, /api/* fica aberto. Recomendado defini-la sempre.
DASHBOARD_PASSWORD=

# ─── Whisper / TTS (opcional) ────────────────────────────────
# URL do servidor Whisper (se tiver um)
WHISPER_API_URL=
# URL fallback do Whisper
WHISPER_API_FALLBACK=
# Caminho local do whisper (se instalado localmente)
WHISPER_PATH=
# Modelo whisper (tiny, base, small, medium, large)
WHISPER_MODEL=tiny
