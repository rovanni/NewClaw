# NewClaw — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# ─── Telegram (obrigatório) ───────────────────────────────────
# Token do bot: Telegram → @BotFather → /newbot → copie o token
TELEGRAM_BOT_TOKEN=

# Seu ID de usuário: Telegram → @userinfobot → copie o ID
TELEGRAM_ALLOWED_USER_IDS=

# ─── Idioma ───────────────────────────────────────────────────
# Opções: pt-BR | en-US | es-ES
APP_LANG=pt-BR

# ─── Provider padrão ─────────────────────────────────────────
# Opções: ollama | gemini | deepseek | groq
DEFAULT_PROVIDER=ollama

# ─── API Keys (opcional — apenas se usar providers em nuvem) ──
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# ─── Ollama (local / nuvem) ───────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=glm-5:cloud
# Deixe vazio se não usa autenticação no Ollama
OLLAMA_API_KEY=

# ─── Config ───────────────────────────────────────────────────
MAX_ITERATIONS=8
MEMORY_WINDOW_SIZE=20
SKILLS_DIR=./skills
TMP_DIR=./workspace/tmp

# ─── Dashboard Web ────────────────────────────────────────────
DASHBOARD_PORT=3090

# ─── Whisper / TTS (opcional) ────────────────────────────────
# URL do servidor Whisper (se tiver um)
WHISPER_API_URL=
# Caminho local do whisper (se instalado localmente)
WHISPER_PATH=