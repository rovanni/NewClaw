#!/usr/bin/env node
/**
 * NewClaw CLI — Command-line interface for NewClaw agent
 * Usage: node bin/newclaw <command> [options]
 * 
 * Commands: start, stop, restart, status, logs, update, help
 */
const { execSync, spawn, exec } = require('child_process');
const fs = require('fs');
const path = require('path');

const DIR = path.resolve(__dirname, '..');
const PID_FILE = path.join(DIR, 'newclaw.pid');
const LOG_FILE = '/tmp/newclaw.log';
const ENV_FILE = fs.existsSync(path.join(DIR, 'newclaw.env')) 
  ? path.join(DIR, 'newclaw.env') 
  : path.join(DIR, '.env');

function getPid() {
  try {
    const pid = fs.readFileSync(PID_FILE, 'utf8').trim();
    if (process.kill(pid, 0)) return parseInt(pid);
  } catch {}
  return null;
}

function isRunning() {
  const pid = getPid();
  return pid !== null;
}

function readEnv() {
  const env = {};
  if (fs.existsSync(ENV_FILE)) {
    fs.readFileSync(ENV_FILE, 'utf8').split('\n').forEach(line => {
      const m = line.match(/^([^#=]+)=(.*)$/);
      if (m) env[m[1].trim()] = m[2].trim();
    });
  }
  return env;
}

function writeEnv(env) {
  const lines = Object.entries(env).map(([k, v]) => `${k}=${v}`);
  fs.writeFileSync(ENV_FILE, lines.join('\n') + '\n');
}

function tailLog(logDir, daemon) {
  const logPath = path.join(logDir, 'newclaw-stdout.log');
  
  // Show recent
  try {
    const content = fs.readFileSync(logPath, 'utf8');
    const lines = content.split(/\r?\n/).filter(Boolean);
    const recent = lines.slice(-30);
    if (recent.length > 0) console.log(recent.join('\n'));
  } catch {}
  
  // Follow
  let offset = 0;
  try { offset = fs.statSync(logPath).size; } catch {}
  
  fs.watchFile(logPath, { interval: 400 }, () => {
    try {
      const stats = fs.statSync(logPath);
      if (stats.size > offset) {
        const stream = fs.createReadStream(logPath, { encoding: 'utf8', start: offset, end: stats.size - 1 });
        offset = stats.size;
        stream.on('data', chunk => process.stdout.write(chunk));
      }
    } catch {}
  });
  
  process.on('SIGINT', () => {
    fs.unwatchFile(logPath);
    console.log('\n📡 Log tail stopped');
    process.exit(0);
  });
}

const commands = {
  start(args) {
    if (isRunning()) { console.log(`🟢 NewClaw already running (PID ${getPid()})`); return; }
    const daemon = args.includes('--daemon');
    const debug = args.includes('--debug');
    const tail = args.includes('--tail');
    
    // Load .env
    const env = readEnv();
    if (debug) env.LOG_LEVEL = 'debug';
    
    // Check lang override
    const langArg = args.find(a => a.startsWith('--lang='));
    if (langArg) env.APP_LANG = langArg.split('=')[1];
    
    const envStr = Object.entries(env).map(([k,v]) => `${k}=${v}`).join(' ');
    const logDir = path.join(DIR, 'logs');
    
    if (daemon) {
      fs.mkdirSync(logDir, { recursive: true });
      const outLog = fs.openSync(path.join(logDir, 'newclaw-stdout.log'), 'a');
      const errLog = fs.openSync(path.join(logDir, 'newclaw-stderr.log'), 'a');
      
      const child = spawn('node', ['dist/index.js'], {
        cwd: DIR,
        stdio: ['ignore', outLog, errLog],
        env: { ...process.env, ...env },
        detached: true
      });
      
      fs.writeFileSync(PID_FILE, child.pid.toString());
      child.unref();
      
      console.log(`🚀 NewClaw started (daemon, PID ${child.pid})`);
      console.log(`   Mode: ${debug ? 'debug' : 'normal'}`);
      console.log(`   Logs: ${logDir}/`);
      
      if (tail) {
        console.log('\n📡 Tailing logs (Ctrl+C to stop)...\n');
        tailLog(logDir, true);
      }
      return;
    }
    
    // Foreground: use exec to replace current process (systemd-compatible)
    // This ensures systemd tracks the correct PID and doesn't restart in a loop
    fs.mkdirSync(logDir, { recursive: true });
    
    if (tail) {
      const logPath = path.join(logDir, 'newclaw-stdout.log');
      fs.closeSync(fs.openSync(logPath, 'a'));
      
      const child = spawn('node', ['dist/index.js'], {
        cwd: DIR,
        stdio: ['inherit', 'ignore', 'ignore'],
        env: { ...process.env, ...env }
      });
      
      fs.writeFileSync(PID_FILE, child.pid.toString());
      
      // Show recent + follow
      try {
        const content = fs.readFileSync(logPath, 'utf8');
        const lines = content.split(/\r?\n/).filter(Boolean);
        const recent = lines.slice(-30);
        if (recent.length > 0) console.log(recent.join('\n'));
      } catch {}
      
      let offset = 0;
      try { offset = fs.statSync(logPath).size; } catch {}
      
      fs.watchFile(logPath, { interval: 400 }, () => {
        try {
          const stats = fs.statSync(logPath);
          if (stats.size > offset) {
            const stream = fs.createReadStream(logPath, { encoding: 'utf8', start: offset, end: stats.size - 1 });
            offset = stats.size;
            stream.on('data', chunk => process.stdout.write(chunk));
          }
        } catch {}
      });
      
      process.on('SIGINT', () => {
        fs.unwatchFile(logPath);
        if (!child.killed) child.kill('SIGINT');
        process.exit(0);
      });
    } else {
      // Plain foreground: exec into node process (PID preserved for systemd)
      const envVars = Object.entries(env).map(([k,v]) => `${k}=${v}`).join(' ');
      process.env = { ...process.env, ...env };
      fs.writeFileSync(PID_FILE, process.pid.toString());
      process.chdir(DIR);
      // Use exec to replace the shell process — systemd tracks THIS pid
      try { require('child_process').execSync('node dist/index.js', { stdio: 'inherit', env: process.env, cwd: DIR }); } 
      catch (e) { if (e.status !== 0) process.exit(e.status || 1); }
    }
  },

  stop() {
    const pid = getPid();
    if (!pid) { console.log('⚪ NewClaw is not running'); return; }
    try { process.kill(pid, 'SIGTERM'); } catch {}
    try { fs.unlinkSync(PID_FILE); } catch {}
    console.log('🛑 NewClaw stopped');
  },

  restart(args) {
    commands.stop();
    setTimeout(() => commands.start([...args, '--daemon']), 2000);
  },

  status(args) {
    const pid = getPid();
    const env = readEnv();
    if (!pid) { console.log('⚪ NewClaw is not running'); return; }
    
    let uptime = 'unknown';
    try {
      const out = execSync(`ps -p ${pid} -o etimes=`).toString().trim();
      const secs = parseInt(out);
      const m = Math.floor(secs / 60);
      const h = Math.floor(m / 60);
      uptime = h > 0 ? `${h}h ${m % 60}m` : `${m}m`;
    } catch {}
    
    console.log(`🟢 NewClaw running (PID ${pid}, uptime ${uptime})`);
    console.log(`   Model: ${env.OLLAMA_MODEL || 'glm-5.1:cloud'}`);
    console.log(`   Lang: ${env.APP_LANG || 'pt-BR'}`);
    console.log(`   Whisper API: ${env.WHISPER_API_URL || 'localhost:8177'}`);
    console.log(`   Dashboard: http://localhost:${env.DASHBOARD_PORT || 3090}`);
    
    const langArg = args?.find(a => a.startsWith('--lang='));
    if (langArg) {
      const lang = langArg.split('=')[1];
      env.APP_LANG = lang;
      writeEnv(env);
      console.log(`   Lang updated to: ${lang}`);
    }
  },

  lang() {
    const env = readEnv();
    console.log(`Current: ${env.APP_LANG || 'pt-BR'}`);
    console.log('Usage: node bin/newclaw lang <locale>  (e.g. pt-BR, en-US)');
  },

  logs(args) {
    const logDir = path.join(DIR, 'logs');
    const stdoutLog = path.join(logDir, 'newclaw-stdout.log');
    const follow = args?.includes('--follow') || args?.includes('-f');
    
    if (!fs.existsSync(stdoutLog)) {
      // Fallback to old log location
      if (fs.existsSync(LOG_FILE)) {
        if (follow) {
          const child = spawn('tail', ['-f', LOG_FILE], { stdio: 'inherit' });
          process.on('SIGINT', () => { child.kill(); process.exit(0); });
        } else {
          try {
            const out = execSync(`tail -50 ${LOG_FILE}`).toString();
            console.log(out);
          } catch { console.log('No logs found'); }
        }
      } else {
        console.log('No logs found. Start NewClaw first.');
      }
      return;
    }
    
    if (follow) {
      tailLog(logDir, false);
    } else {
      try {
        const out = execSync(`tail -50 ${stdoutLog}`).toString();
        console.log(out);
      } catch { console.log('No logs found'); }
    }
  },

  update(args) {
    const restart = args?.includes('restart') || args?.includes('-r');
    const force = args?.includes('--force') || args?.includes('-f');
    console.log('🔄 Atualizando NewClaw...');
    try {
      // 1. Fetch remote
      execSync('git fetch origin main', { cwd: DIR, stdio: 'inherit' });
      const local = execSync('git rev-parse HEAD', { cwd: DIR }).toString().trim();
      const remote = execSync('git rev-parse origin/main', { cwd: DIR }).toString().trim();
      
      if (local === remote) {
        console.log('✅ Sistema já está na versão mais recente.');
        return;
      }

      console.log(`📥 Atualizando: ${local.slice(0,7)} → ${remote.slice(0,7)}`);

      // 2. Protect user files: backup .env and critical dirs
      const protectedFiles = [];
      const envBackup = path.join(DIR, '.env.update-backup');
      if (fs.existsSync(ENV_FILE)) {
        fs.copyFileSync(ENV_FILE, envBackup);
        protectedFiles.push('.env');
      }

      // 3. Stash any local changes (safe — won't lose anything)
      let hasStash = false;
      try {
        const stashOut = execSync('git stash --include-untracked', { cwd: DIR }).toString();
        hasStash = !stashOut.includes('No local changes');
        if (hasStash) console.log('📦 Alterações locais salvas (git stash)');
      } catch { /* no changes to stash — fine */ }

      // 4. Pull with rebase (cleanest merge)
      let pullOk = false;
      try {
        execSync('git pull --rebase origin main', { cwd: DIR, stdio: 'inherit' });
        pullOk = true;
      } catch {
        // 5. Fallback: hard reset (guaranteed to work)
        console.log('⚠️  Pull falhou, fazendo sync forçado...');
        try {
          execSync('git rebase --abort', { cwd: DIR, stdio: 'ignore' });
        } catch { /* no rebase in progress */ }
        execSync('git reset --hard origin/main', { cwd: DIR, stdio: 'inherit' });
        pullOk = true;
      }

      // 6. Try to restore stashed changes (non-critical files)
      if (hasStash) {
        try {
          execSync('git stash pop', { cwd: DIR, stdio: 'ignore' });
          console.log('📦 Alterações locais restauradas');
        } catch {
          // Conflicts — keep stash, user can recover with `git stash list`
          console.log('⚠️  Conflitos ao restaurar alterações locais (salvas em `git stash list`)');
        }
      }

      // 7. Always restore .env (most critical user file)
      if (fs.existsSync(envBackup)) {
        fs.copyFileSync(envBackup, ENV_FILE);
        fs.unlinkSync(envBackup);
        console.log('🔒 .env restaurado com sucesso');
      }

      // 8. Install deps if package.json changed
      try {
        const diff = execSync(`git diff ${local}..${remote} --name-only`, { cwd: DIR }).toString();
        if (diff.includes('package.json') || diff.includes('package-lock.json')) {
          console.log('📦 Dependências alteradas, instalando...');
          execSync('npm install --production', { cwd: DIR, stdio: 'inherit' });
        }
      } catch { /* ignore */ }

      // 9. Build
      console.log('🔧 Compilando projeto...');
      execSync('npm run build', { cwd: DIR, stdio: 'inherit' });
      
      if (restart) {
        console.log('🔄 Reiniciando...');
        commands.restart(['--daemon']);
      } else {
        console.log('⚠️  Build concluído. Execute "newclaw update restart" para aplicar as mudanças.');
      }
      console.log('✅ Atualização concluída!');
    } catch (e) {
      // Emergency: restore .env if it was backed up
      const envBackup = path.join(DIR, '.env.update-backup');
      if (fs.existsSync(envBackup)) {
        try { fs.copyFileSync(envBackup, ENV_FILE); fs.unlinkSync(envBackup); } catch {}
      }
      console.error('❌ Falha na atualização:', e.message);
      console.log('💡 Tente: newclaw update --force');
    }
  },

  restore() {
    const isWin = process.platform === 'win32';
    const script = isWin ? 'restore.ps1' : 'restore.sh';
    const scriptPath = path.join(DIR, 'scripts', script);
    
    if (!fs.existsSync(scriptPath)) {
      console.error(`❌ Erro: Script de restauração não encontrado em ${scriptPath}`);
      return;
    }

    console.log('🔄 Iniciando assistente de restauração...');
    if (isWin) {
      spawn('powershell.exe', ['-ExecutionPolicy', 'Bypass', '-File', scriptPath], { stdio: 'inherit' });
    } else {
      spawn('bash', [scriptPath], { stdio: 'inherit' });
    }
  },

  uninstall() {
    const isWin = process.platform === 'win32';
    const script = isWin ? 'uninstall.ps1' : 'uninstall.sh';
    const scriptPath = path.join(DIR, script);
    
    if (!fs.existsSync(scriptPath)) {
      console.error(`❌ Erro: Script de desinstalação não encontrado em ${scriptPath}`);
      return;
    }

    console.log('⚠️  Iniciando desinstalador...');
    if (isWin) {
      spawn('powershell.exe', ['-ExecutionPolicy', 'Bypass', '-File', scriptPath], { stdio: 'inherit' });
    } else {
      spawn('bash', [scriptPath], { stdio: 'inherit' });
    }
  },

  onboard() {
    const readline = require('readline').createInterface({
      input: process.stdin,
      output: process.stdout
    });

    const env = readEnv();
    console.log('\n🪐 NewClaw Onboarding — Assistente de Configuração');
    console.log('Este assistente ajudará você a configurar seus provedores de IA.\n');

    const providers = ['OpenRouter', 'Gemini', 'DeepSeek', 'Groq', 'Ollama'];
    console.log('Escolha um provedor de IA:');
    providers.forEach((p, i) => console.log(`${i + 1}. ${p}`));

    readline.question('\nOpção (1-5): ', (choice) => {
      const idx = parseInt(choice) - 1;
      if (idx < 0 || idx >= providers.length) {
        console.log('❌ Opção inválida.');
        readline.close();
        return;
      }

      const provider = providers[idx].toLowerCase();
      env.DEFAULT_PROVIDER = provider;

      if (provider === 'ollama') {
        readline.question('URL do Ollama (default: http://localhost:11434): ', (url) => {
          env.OLLAMA_URL = url || 'http://localhost:11434';
          readline.question('Modelo do Ollama (ex: glm-5.1:cloud): ', (model) => {
            env.OLLAMA_MODEL = model || 'glm-5.1:cloud';
            writeEnv(env);
            console.log('\n✅ Configuração do Ollama salva!');
            readline.close();
          });
        });
      } else {
        const keyMap = {
          openrouter: 'OPENROUTER_API_KEY',
          gemini: 'GEMINI_API_KEY',
          deepseek: 'DEEPSEEK_API_KEY',
          groq: 'GROQ_API_KEY'
        };
        const envKey = keyMap[provider];
        readline.question(`Insira sua API Key do ${providers[idx]}: `, (key) => {
          if (key) env[envKey] = key;
          
          let defaultModel = 'anthropic/claude-3.5-sonnet';
          if (provider === 'gemini') defaultModel = 'gemini-2.0-flash';
          if (provider === 'deepseek') defaultModel = 'deepseek-chat';
          if (provider === 'groq') defaultModel = 'llama-3.3-70b-versatile';

          readline.question(`Modelo preferido (default: ${defaultModel}): `, (model) => {
            const finalModel = model || defaultModel;
            if (provider === 'openrouter') env.MODEL_CHAT = finalModel;
            else if (provider === 'ollama') env.OLLAMA_MODEL = finalModel;
            
            writeEnv(env);
            console.log(`\n✅ Configuração do ${providers[idx]} salva em .env!`);
            console.log(`💡 Provedor padrão definido como: ${provider}`);
            readline.close();
          });
        });
      }
    });
  },

  help() {
    console.log(`
🪐 NewClaw CLI — Referência de Comandos

Comando                 Descrição
----------------------- ----------------------------------------------------
newclaw onboard         Configura provedores e chaves de API
newclaw channels         Status dos canais (telegram, discord, whatsapp, signal)
newclaw channels enable <canal>   Configura um canal
newclaw channels disable <canal>  Desativa um canal
newclaw start           Inicia o agente (foreground)
newclaw start --daemon  Inicia em segundo plano (ideal para VPS)
newclaw stop            Encerra o serviço graciosamente
newclaw status          Mostra o status, PID, uptime e configurações
newclaw logs -f         Visualiza os logs em tempo real
newclaw update          Atualiza o código do GitHub e recompila o projeto
newclaw update restart  Atualiza e reinicia automaticamente
newclaw restore         Abre o assistente de restauração de backups
newclaw uninstall       Remove o NewClaw e limpa o sistema
newclaw help            Mostra esta tela de ajuda

Exemplos:
  newclaw onboard
  newclaw start --daemon --tail
  newclaw status --lang=pt-BR
  newclaw update restart
  newclaw logs -f

Dicas:
  - Use --debug para ver logs detalhados (LOG_LEVEL=debug)
  - Backups são armazenados em: ~/newclaw-backups (Linux) ou %USERPROFILE%\\newclaw-backups (Windows)
  - Logs detalhados em: ./logs/newclaw-stdout.log
`);
  },

  channels(args) {
    const env = readEnv();
    const subcommand = args && args[0] ? args[0] : 'status';

    switch (subcommand) {
      case 'status': {
        console.log('');
        console.log('📡 NewClaw — Status dos Canais');
        console.log('');
        const channels = [
          { name: 'Telegram', key: 'TELEGRAM_BOT_TOKEN', icon: '✅' },
          { name: 'Discord', key: 'DISCORD_BOT_TOKEN', icon: '🟡' },
          { name: 'WhatsApp', key: 'WHATSAPP_PHONE_NUMBER', icon: '🟡' },
          { name: 'Signal', key: 'SIGNAL_PHONE_NUMBER', icon: '🟡' },
        ];
        for (const ch of channels) {
          const hasCreds = !!env[ch.key];
          const status = hasCreds ? ch.icon + ' Configurado' : '⬜️ Não configurado';
          const detail = hasCreds ? ch.key + '=' + env[ch.key].substring(0, 10) + '...' : 'Adicione ' + ch.key + ' ao .env';
          console.log('  ' + ch.name.padEnd(12) + ' ' + status);
          console.log('  ' + ''.padEnd(12) + ' ' + detail);
        }
        console.log('');
        console.log('  Use: newclaw channels enable <canal>  para configurar um canal');
        console.log('  Canais: telegram, discord, whatsapp, signal');
        break;
      }

      case 'enable': {
        const channel = args && args[1] ? args[1] : '';
        if (!channel) {
          console.log('❌ Use: newclaw channels enable <telegram|discord|whatsapp|signal>');
          return;
        }
        const readline = require('readline').createInterface({ input: process.stdin, output: process.stdout });
        const configs = {
          telegram: [
            { key: 'TELEGRAM_BOT_TOKEN', prompt: 'Cole o Bot Token do Telegram (@BotFather)', hint: 'Ex: 123456:ABCdefGHI...' },
            { key: 'TELEGRAM_ALLOWED_USER_IDS', prompt: 'Seu User ID (@userinfobot)', hint: 'Ex: 987654321' },
          ],
          discord: [
            { key: 'DISCORD_BOT_TOKEN', prompt: 'Cole o Bot Token do Discord (Developer Portal → Bot)', hint: 'Ex: MTk4Nj...' },
            { key: 'DISCORD_ALLOWED_GUILD_IDS', prompt: 'IDs dos servidores permitidos (vírgula, vazio = todos)', hint: 'Ex: 123456789012345678' },
            { key: 'DISCORD_ALLOWED_USER_IDS', prompt: 'IDs de usuários permitidos (vírgula, vazio = todos)', hint: 'Ex: 123456789' },
          ],
          whatsapp: [
            { key: 'WHATSAPP_PHONE_NUMBER', prompt: 'Número de telefone com código do país', hint: 'Ex: 5511999999999 (sem +)' },
            { key: 'WHATSAPP_ALLOWED_JIDS', prompt: 'JIDs permitidos (vírgula, vazio = todos os contatos)', hint: 'Ex: 5511999999999@s.whatsapp.net' },
          ],
          signal: [
            { key: 'SIGNAL_PHONE_NUMBER', prompt: 'Número de telefone com código do país', hint: 'Ex: +5511999999999' },
            { key: 'SIGNAL_ALLOWED_NUMBERS', prompt: 'Números permitidos (vírgula, vazio = todos)', hint: 'Ex: +5511999999999' },
          ],
        };
        const fields = configs[channel];
        if (!fields) {
          console.log('❌ Canal desconhecido: ' + channel);
          console.log('Canais disponíveis: telegram, discord, whatsapp, signal');
          readline.close();
          return;
        }
        console.log('');
        console.log('📡 Configurando ' + channel.charAt(0).toUpperCase() + channel.slice(1));
        console.log('');
        let idx = 0;
        const askField = () => {
          if (idx >= fields.length) {
            writeEnv(env);
            console.log('');
            console.log('✅ ' + channel.charAt(0).toUpperCase() + channel.slice(1) + ' configurado!');
            console.log('💡 Reinicie o NewClaw para aplicar: newclaw restart');
            readline.close();
            return;
          }
          const field = fields[idx];
          const current = env[field.key] || '';
          const defaultHint = current ? ' [atual: ' + current.substring(0, 15) + (current.length > 15 ? '...' : '') + ']' : (field.hint ? ' (' + field.hint + ')' : '');
          readline.question('  ' + field.prompt + defaultHint + ': ', (answer) => {
            env[field.key] = answer || current;
            idx++;
            askField();
          });
        };
        askField();
        break;
      }

      case 'disable': {
        const channel = args && args[1] ? args[1] : '';
        if (!channel) {
          console.log('❌ Use: newclaw channels disable <telegram|discord|whatsapp|signal>');
          return;
        }
        const keyMap = {
          telegram: ['TELEGRAM_BOT_TOKEN', 'TELEGRAM_ALLOWED_USER_IDS'],
          discord: ['DISCORD_BOT_TOKEN', 'DISCORD_ALLOWED_GUILD_IDS', 'DISCORD_ALLOWED_USER_IDS'],
          whatsapp: ['WHATSAPP_PHONE_NUMBER', 'WHATSAPP_ALLOWED_JIDS', 'WHATSAPP_AUTH_DIR'],
          signal: ['SIGNAL_PHONE_NUMBER', 'SIGNAL_ALLOWED_NUMBERS', 'SIGNAL_CLI_PATH'],
        };
        const keys = keyMap[channel];
        if (!keys) {
          console.log('❌ Canal desconhecido: ' + channel);
          return;
        }
        for (const key of keys) {
          if (env[key] !== undefined) env[key] = '';
        }
        writeEnv(env);
        console.log('✅ ' + channel.charAt(0).toUpperCase() + channel.slice(1) + ' desativado!');
        console.log('💡 Reinicie o NewClaw para aplicar: newclaw restart');
        break;
      }

      default:
        console.log('❌ Subcomando desconhecido. Use: status, enable, disable');
    }
  },
};

// Parse args
const args = process.argv.slice(2);
const command = args[0] || 'help';
const rest = args.slice(1);

if (commands[command]) {
  commands[command](rest);
} else {
  console.log(`❌ Unknown command: ${command}`);
  commands.help();
}