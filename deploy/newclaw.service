[Unit]
Description=NewClaw AI Agent
After=network.target ollama.service
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
User=venus
WorkingDirectory=/home/venus/newclaw
ExecStart=/usr/bin/node bin/newclaw start
ExecStop=/usr/bin/node bin/newclaw stop
Restart=on-failure
RestartSec=10
Environment=NODE_ENV=production

# Ensure all child processes are killed on stop/restart
KillMode=control-group
KillSignal=SIGTERM
TimeoutStopSec=30

# Crash loop protection
RestartPreventExitStatus=1 2
# WatchdogSec=120
# DISABLED: Node.js does not implement sd_notify(). Without watchdog
# notifications, systemd kills the process every 2min with SIGABRT.
# Re-enable ONLY after implementing sd-notify in the codebase
# (npm install sd-notify + setInterval(() => sdNotify.watchdog(), 30000))
# and changing Type=notify.

[Install]
WantedBy=multi-user.target